{
  "name": "@codex-realtime/contracts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ipc": {
      "types": "./dist/ipc.d.ts",
      "import": "./dist/ipc.js"
    },
    "./provider-runtime": {
      "types": "./dist/provider-runtime.d.ts",
      "import": "./dist/provider-runtime.js"
    },
    "./shell-api": {
      "types": "./dist/shell-api.d.ts",
      "import": "./dist/shell-api.js"
    },
    "./server-api": {
      "types": "./dist/server-api.d.ts",
      "import": "./dist/server-api.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
