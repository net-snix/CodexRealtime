{
  "name": "codex-realtime",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "pnpm --filter @codex-realtime/desktop dev",
    "build": "pnpm --filter @codex-realtime/contracts build && pnpm --filter @codex-realtime/shared build && pnpm --filter @codex-realtime/desktop build",
    "cleanup:helpers": "bash ./scripts/cleanup-helper-processes.sh",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @codex-realtime/desktop test:e2e"
  },
  "devDependencies": {
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "playwright": "^1.58.2",
    "typescript-eslint": "^8.56.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
